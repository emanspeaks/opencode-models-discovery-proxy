{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "opencode-models-discovery-proxy",
  "version": "0.8.6",
  "description": "OpenCode plugin for auto-discovery of OpenAI-compatible models with dynamic provider configuration",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "build": "bun run typecheck && bun run test:run",
    "validate": "bun run lint && bun run typecheck && bun run test:run",
    "validate:config": "bun scripts/validate-config.ts",
    "release": "bun scripts/release.ts",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "opencode",
    "openai-compatible",
    "model-discovery",
    "plugin",
    "local-llm",
    "ollama",
    "lmstudio",
    "lm-studio",
    "localai"
  ],
  "author": {
    "name": "Randy Eckman",
    "url": "https://github.com/emanspeaks"
  },
  "license": "MIT",
  "homepage": "https://github.com/emanspeaks/opencode-models-discovery-proxy#readme",
  "bugs": {
    "url": "https://github.com/emanspeaks/opencode-models-discovery-proxy/issues"
  },
  "engines": {
    "opencode": ">=1.4.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emanspeaks/opencode-models-discovery-proxy.git"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.166"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
